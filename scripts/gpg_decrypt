#!/usr/bin/env bash

set -euo pipefail

KEEP_ENCRYPTED=false
PASSPHRASE_FILE=""
OUTPUT=""

while [[ $# -gt 0 ]]; do
  case $1 in
  -k | --keep)
    KEEP_ENCRYPTED=true
    shift
    ;;
  -p | --passphrase-file)
    PASSPHRASE_FILE="$2"
    shift 2
    ;;
  -o | --output)
    OUTPUT="$2"
    shift 2
    ;;
  -h | --help)
    echo "Usage: $0 [OPTIONS] <file.gpg|directory>"
    echo
    echo "Decrypt a GPG-encrypted file or every .gpg/.asc file in a directory."
    echo
    echo "Options:"
    echo "  -k, --keep                Keep encrypted file(s) after decryption (default: remove)"
    echo "  -p, --passphrase-file F   Read passphrase from file F (default: interactive prompt)"
    echo "  -o, --output FILE         Output file path (single file only; default: strip .gpg extension)"
    echo "  -h, --help                Show this help"
    echo
    echo "Examples:"
    echo "  $0 secret.pdf.gpg"
    echo "  $0 -k -o decrypted.pdf secret.pdf.gpg"
    echo "  $0 -p ~/.passphrase secret.pdf.gpg"
    echo "  $0 ~/Documents/sensitive/"
    exit 0
    ;;
  -*)
    echo "Error: Unknown option '$1'. Use -h for help." >&2
    exit 1
    ;;
  *)
    INPUT_PATH="$1"
    shift
    ;;
  esac
done

if [ -z "${INPUT_PATH:-}" ]; then
  echo "Error: No input file or directory specified. Use -h for help." >&2
  exit 1
fi

if [ ! -e "$INPUT_PATH" ]; then
  echo "Error: '$INPUT_PATH' does not exist." >&2
  exit 1
fi

if ! command -v gpg &>/dev/null; then
  echo "Error: gpg is not installed." >&2
  exit 1
fi

if [ -d "$INPUT_PATH" ] && [ -n "$OUTPUT" ]; then
  echo "Error: -o/--output cannot be used with a directory." >&2
  exit 1
fi

PASSPHRASE_ARGS=()
if [ -n "$PASSPHRASE_FILE" ]; then
  if [ ! -f "$PASSPHRASE_FILE" ]; then
    echo "Error: Passphrase file '$PASSPHRASE_FILE' does not exist." >&2
    exit 1
  fi
  PASSPHRASE_ARGS=(--batch --yes --pinentry-mode loopback --passphrase-file "$PASSPHRASE_FILE")
fi

output_for_file() {
  local f="$1"
  case "$f" in
  *.gpg) echo "${f%.gpg}" ;;
  *.asc) echo "${f%.asc}" ;;
  *) echo "${f}.decrypted" ;;
  esac
}

decrypt_file() {
  local input="$1"
  local output="${2:-$(output_for_file "$input")}"

  if [ -f "$output" ]; then
    echo "Skipping: Output file '$output' already exists." >&2
    return 1
  fi

  echo "Decrypting: $input -> $output"

  if gpg --decrypt \
    --no-symkey-cache \
    "${PASSPHRASE_ARGS[@]}" \
    --output "$output" \
    "$input" && [ -f "$output" ]; then
    echo "Decrypted successfully: $output ($(du -h "$output" | cut -f1))"

    if [ "$KEEP_ENCRYPTED" = false ]; then
      rm -f "$input"
      echo "Encrypted file removed."
    else
      echo "Encrypted file kept."
    fi
  else
    echo "Error: Decryption failed for '$input'." >&2
    return 1
  fi
}

FAIL_COUNT=0

if [ -d "$INPUT_PATH" ]; then
  FILE_COUNT=0
  while IFS= read -r -d '' file; do
    FILE_COUNT=$((FILE_COUNT + 1))
    decrypt_file "$file" || FAIL_COUNT=$((FAIL_COUNT + 1))
  done < <(find "$INPUT_PATH" -maxdepth 1 -type f \( -name '*.gpg' -o -name '*.asc' \) -print0 | sort -z)

  if [ "$FILE_COUNT" -eq 0 ]; then
    echo "No .gpg or .asc files found in '$INPUT_PATH'."
    exit 0
  fi
  echo "Done: $((FILE_COUNT - FAIL_COUNT))/$FILE_COUNT files decrypted."
  [ "$FAIL_COUNT" -eq 0 ] || exit 1
else
  decrypt_file "$INPUT_PATH" "$OUTPUT"
fi
