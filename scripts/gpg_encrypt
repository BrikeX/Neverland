#!/usr/bin/env bash

set -euo pipefail

KEEP_ORIGINAL=false
PASSPHRASE_FILE=""
OUTPUT=""

while [[ $# -gt 0 ]]; do
  case $1 in
  -k | --keep)
    KEEP_ORIGINAL=true
    shift
    ;;
  -p | --passphrase-file)
    PASSPHRASE_FILE="$2"
    shift 2
    ;;
  -o | --output)
    OUTPUT="$2"
    shift 2
    ;;
  -h | --help)
    echo "Usage: $0 [OPTIONS] <file|directory>"
    echo
    echo "Encrypt a file or every file in a directory with GPG (AES-256, max S2K iterations)."
    echo
    echo "Options:"
    echo "  -k, --keep                Keep original file(s) after encryption (default: remove)"
    echo "  -p, --passphrase-file F   Read passphrase from file F (default: interactive prompt)"
    echo "  -o, --output FILE         Output file path (single file only; default: <input>.gpg)"
    echo "  -h, --help                Show this help"
    echo
    echo "Examples:"
    echo "  $0 secret.pdf"
    echo "  $0 -k -o encrypted.gpg secret.pdf"
    echo "  $0 -p ~/.passphrase secret.pdf"
    echo "  $0 ~/Documents/sensitive/"
    exit 0
    ;;
  -*)
    echo "Error: Unknown option '$1'. Use -h for help." >&2
    exit 1
    ;;
  *)
    INPUT_PATH="$1"
    shift
    ;;
  esac
done

if [ -z "${INPUT_PATH:-}" ]; then
  echo "Error: No input file or directory specified. Use -h for help." >&2
  exit 1
fi

if [ ! -e "$INPUT_PATH" ]; then
  echo "Error: '$INPUT_PATH' does not exist." >&2
  exit 1
fi

if ! command -v gpg &>/dev/null; then
  echo "Error: gpg is not installed." >&2
  exit 1
fi

if [ -d "$INPUT_PATH" ] && [ -n "$OUTPUT" ]; then
  echo "Error: -o/--output cannot be used with a directory." >&2
  exit 1
fi

PASSPHRASE_ARGS=()
if [ -n "$PASSPHRASE_FILE" ]; then
  if [ ! -f "$PASSPHRASE_FILE" ]; then
    echo "Error: Passphrase file '$PASSPHRASE_FILE' does not exist." >&2
    exit 1
  fi
  PASSPHRASE_ARGS=(--batch --yes --pinentry-mode loopback --passphrase-file "$PASSPHRASE_FILE")
fi

encrypt_file() {
  local input="$1"
  local output="${2:-${input}.gpg}"

  if [ -f "$output" ]; then
    echo "Skipping: Output file '$output' already exists." >&2
    return 1
  fi

  echo "Encrypting: $input -> $output"

  if gpg --symmetric \
    --cipher-algo AES256 \
    --digest-algo SHA512 \
    --s2k-digest-algo SHA512 \
    --s2k-mode 3 \
    --s2k-count 65011712 \
    --set-filename "" \
    --no-symkey-cache \
    "${PASSPHRASE_ARGS[@]}" \
    --output "$output" \
    "$input" && [ -f "$output" ]; then
    echo "Encrypted successfully: $output ($(du -h "$output" | cut -f1))"

    if [ "$KEEP_ORIGINAL" = false ]; then
      rm -f "$input"
      echo "Original file removed."
    else
      echo "Original file kept."
    fi
  else
    echo "Error: Encryption failed for '$input'." >&2
    return 1
  fi
}

FAIL_COUNT=0

if [ -d "$INPUT_PATH" ]; then
  FILE_COUNT=0
  while IFS= read -r -d '' file; do
    FILE_COUNT=$((FILE_COUNT + 1))
    encrypt_file "$file" || FAIL_COUNT=$((FAIL_COUNT + 1))
  done < <(find "$INPUT_PATH" -maxdepth 1 -type f -not -name '*.gpg' -print0 | sort -z)

  if [ "$FILE_COUNT" -eq 0 ]; then
    echo "No files found in '$INPUT_PATH'."
    exit 0
  fi
  echo "Done: $((FILE_COUNT - FAIL_COUNT))/$FILE_COUNT files encrypted."
  [ "$FAIL_COUNT" -eq 0 ] || exit 1
else
  encrypt_file "$INPUT_PATH" "$OUTPUT"
fi
