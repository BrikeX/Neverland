#!/usr/bin/env bash

set -euo pipefail

KEEP_ORIGINAL=false
PASSPHRASE_FILE=""
OUTPUT=""

while [[ $# -gt 0 ]]; do
  case $1 in
  -k | --keep)
    KEEP_ORIGINAL=true
    shift
    ;;
  -p | --passphrase-file)
    PASSPHRASE_FILE="$2"
    shift 2
    ;;
  -o | --output)
    OUTPUT="$2"
    shift 2
    ;;
  -h | --help)
    echo "Usage: $0 [OPTIONS] <file>"
    echo
    echo "Encrypt a file with GPG (AES-256, max S2K iterations)."
    echo
    echo "Options:"
    echo "  -k, --keep                Keep original file after encryption (default: remove)"
    echo "  -p, --passphrase-file F   Read passphrase from file F (default: interactive prompt)"
    echo "  -o, --output FILE         Output file path (default: <input>.gpg)"
    echo "  -h, --help                Show this help"
    echo
    echo "Examples:"
    echo "  $0 secret.pdf"
    echo "  $0 -k -o encrypted.gpg secret.pdf"
    echo "  $0 -p ~/.passphrase secret.pdf"
    exit 0
    ;;
  -*)
    echo "Error: Unknown option '$1'. Use -h for help." >&2
    exit 1
    ;;
  *)
    INPUT_FILE="$1"
    shift
    ;;
  esac
done

if [ -z "${INPUT_FILE:-}" ]; then
  echo "Error: No input file specified. Use -h for help." >&2
  exit 1
fi

if [ ! -f "$INPUT_FILE" ]; then
  echo "Error: File '$INPUT_FILE' does not exist." >&2
  exit 1
fi

if ! command -v gpg &>/dev/null; then
  echo "Error: gpg is not installed." >&2
  exit 1
fi

if [ -z "$OUTPUT" ]; then
  OUTPUT="${INPUT_FILE}.gpg"
fi

if [ -f "$OUTPUT" ]; then
  echo "Error: Output file '$OUTPUT' already exists. Remove it first or use -o." >&2
  exit 1
fi

PASSPHRASE_ARGS=()
if [ -n "$PASSPHRASE_FILE" ]; then
  if [ ! -f "$PASSPHRASE_FILE" ]; then
    echo "Error: Passphrase file '$PASSPHRASE_FILE' does not exist." >&2
    exit 1
  fi
  PASSPHRASE_ARGS=(--batch --yes --pinentry-mode loopback --passphrase-file "$PASSPHRASE_FILE")
fi

echo "Encrypting: $INPUT_FILE -> $OUTPUT"

if gpg --symmetric \
  --cipher-algo AES256 \
  --digest-algo SHA512 \
  --s2k-digest-algo SHA512 \
  --s2k-mode 3 \
  --s2k-count 65011712 \
  --set-filename "" \
  --no-symkey-cache \
  "${PASSPHRASE_ARGS[@]}" \
  --output "$OUTPUT" \
  "$INPUT_FILE" && [ -f "$OUTPUT" ]; then
  echo "Encrypted successfully: $OUTPUT ($(du -h "$OUTPUT" | cut -f1))"

  if [ "$KEEP_ORIGINAL" = false ]; then
    rm -f "$INPUT_FILE"
    echo "Original file removed."
  else
    echo "Original file kept."
  fi
else
  echo "Error: Encryption failed." >&2
  exit 1
fi
